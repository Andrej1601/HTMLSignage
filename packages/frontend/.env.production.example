# Backend API URL — set to the server's IP/hostname and backend port
# The install script generates this automatically.
VITE_API_URL=http://YOUR_SERVER_IP:3000

# Development: override the API proxy target (default: http://localhost:3000)
# VITE_DEV_API_TARGET=http://localhost:3000

# Development: bind dev server to all interfaces (default: localhost)
# Set to 0.0.0.0 to access from other devices on the network.
# VITE_DEV_HOST=0.0.0.0
