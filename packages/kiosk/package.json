{
  "name": "@htmlsignage/kiosk",
  "version": "1.0.0",
  "description": "HTMLSignage Kiosk-Modus Applikation — Vollbild-Display-Client mit Auto-Start und Crash-Recovery",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux --windows",
    "build:linux": "electron-builder --linux deb AppImage",
    "build:windows": "electron-builder --windows nsis"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "de.htmlsignage.kiosk",
    "productName": "HTMLSignage Kiosk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "config.json"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "src/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "src/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
