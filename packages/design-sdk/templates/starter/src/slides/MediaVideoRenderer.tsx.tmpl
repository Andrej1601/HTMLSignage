import { useEffect, useRef } from 'react';
import type { SlideRendererProps } from '@htmlsignage/design-sdk';

/**
 * {{DESIGN_NAME}} — media-video renderer.
 *
 * Starter stub: autoplaying muted video with the `fit` mode applied.
 * Calls `context.onVideoEnded` when playback completes so the host
 * can advance the slideshow.
 */
export function MediaVideoRenderer({ data, tokens, context }: SlideRendererProps<'media-video'>) {
  const { colors } = tokens;
  const ref = useRef<HTMLVideoElement>(null);

  useEffect(() => {
    const el = ref.current;
    if (!el) return;
    el.currentTime = 0;
    void el.play().catch(() => {
      /* autoplay may be blocked; no-op */
    });
  }, [data.url]);

  if (!data.url) {
    return (
      <div
        className="flex h-full w-full items-center justify-center"
        style={{ backgroundColor: colors.surface, color: colors.textSecondary }}
      >
        Kein Video verfügbar.
      </div>
    );
  }

  // Loop when playback mode requests it; otherwise play once and let the
  // host advance via `onVideoEnded`.
  const shouldLoop =
    data.playback === 'duration' || data.playback === 'loop-duration';

  return (
    <div className="h-full w-full" style={{ backgroundColor: colors.surface }}>
      <video
        ref={ref}
        src={data.url}
        muted={data.mutedByDefault}
        playsInline
        autoPlay
        loop={shouldLoop}
        preload="auto"
        className="h-full w-full"
        style={{ objectFit: data.fit === 'contain' ? 'contain' : 'cover' }}
        onEnded={() => context.onVideoEnded?.()}
      />
    </div>
  );
}
