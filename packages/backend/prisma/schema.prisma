generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  username            String               @unique
  email               String?              @unique
  password            String
  roles               String[]             @default(["viewer"])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  auditLogs           AuditLog[]
  devices             Device[]
  mediaUploads        Media[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model Slideshow {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  devices   Device[]
  events    Event[]

  @@index([isDefault])
  @@map("slideshows")
}

// Saunas, aromas, info items and events used to live as JSON arrays
// inside Settings.data. Each is now a first-class table so concurrent
// admin edits don't collide on a mega-document and the relational shape
// can be queried/indexed. Settings.data still mirrors them at GET time
// for backwards compatibility with the existing API consumers.
model Sauna {
  id          String   @id
  name        String
  // Allowed values: 'active' | 'no-aufguss' | 'out-of-order' | 'hidden'
  status      String   @default("active")
  order       Int      @default(0)
  imageId     String?
  color       String?
  description String?
  // Free-form JSON for temperature/humidity/capacity/features.
  info        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@map("saunas")
}

model Aroma {
  id        String   @id
  name      String
  emoji     String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("aromas")
}

model InfoItem {
  id        String   @id
  title     String
  text      String
  imageId   String?
  // Allowed values: 'thumbnail' | 'background'
  imageMode String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("info_items")
}

model Event {
  id               String     @id
  name             String
  description      String?
  imageId          String?
  startDate        String
  startTime        String
  endDate          String?
  endTime          String?
  // Allowed values: 'Evt1' | 'Evt2'
  assignedPreset   String
  isActive         Boolean    @default(true)
  targetDeviceIds  String[]   @default([])
  slideshowId      String?
  order            Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  slideshow        Slideshow? @relation(fields: [slideshowId], references: [id], onDelete: SetNull)

  @@index([slideshowId])
  @@index([isActive])
  @@index([order])
  @@map("events")
}

model Device {
  id              String          @id @default(cuid())
  name            String
  pairingCode     String?         @unique
  mode            String          @default("auto")
  slideshowId     String?
  pairedBy        String?
  pairedAt        DateTime?
  lastSeen        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  groupName       String?
  maintenanceMode Boolean         @default(false)
  tokenRevokedAt  DateTime?
  slideshow       Slideshow?      @relation(fields: [slideshowId], references: [id], onDelete: SetNull)
  overrides       DeviceOverride?
  user            User?           @relation(fields: [pairedBy], references: [id])

  @@index([pairedBy])
  @@index([groupName])
  @@index([lastSeen])
  @@index([maintenanceMode])
  @@index([pairingCode])
  @@index([tokenRevokedAt])
  @@index([slideshowId])
  @@map("devices")
}

model DeviceOverride {
  id       String @id @default(cuid())
  deviceId String @unique
  // Per-device schedule override. The legacy `settings` JSON column was
  // dropped — design/theme/slideshow customisation now lives exclusively on
  // SlideshowConfig and reaches devices via `device.slideshowId`.
  schedule Json
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("device_overrides")
}

model Schedule {
  id        String   @id @default(cuid())
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, version(sort: Desc)])
  @@map("schedules")
}

model Settings {
  id        String   @id @default(cuid())
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, version(sort: Desc)])
  @@map("settings")
}

model Media {
  id           String   @id @default(cuid())
  type         String
  filename     String
  originalName String
  mimeType     String
  size         Int
  tags         String[] @default([])
  uploadedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [uploadedBy], references: [id])

  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([uploadedBy])
  @@map("media")
}

model CustomPalette {
  id        String   @id @default(cuid())
  name      String
  colors    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custom_palettes")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, timestamp(sort: Desc)])
  @@index([action, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@map("audit_logs")
}

model SystemJob {
  id         String    @id @default(cuid())
  type       String
  title      String
  status     String
  requestId  String?
  createdBy  Json?
  progress   Json?
  log        String    @default("")
  result     Json?
  error      Json?
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([status, createdAt(sort: Desc)])
  @@index([type, status])
  @@index([createdAt(sort: Desc)])
  @@map("system_jobs")
}

model RuntimeHistory {
  id                 String   @id @default(cuid())
  timestamp          DateTime @default(now())
  diskUsagePercent   Float
  pairedDevices      Int
  onlineDevices      Int
  offlineDevices     Int
  staleDevices       Int
  neverSeenDevices   Int
  missingMediaFiles  Int
  orphanMediaFiles   Int
  warningCount       Int
  deviceWarningCount Int
  systemWarningCount Int
  maintenanceState   String

  @@index([timestamp(sort: Desc)])
  @@map("runtime_history")
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([key, expiresAt])
  @@index([expiresAt])
  @@map("rate_limits")
}
