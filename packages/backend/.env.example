# Database
DATABASE_URL="postgresql://signage:password@localhost:5432/htmlsignage?schema=public"
# Optional: tune Prisma connection pool size (default 10)
DATABASE_POOL_MAX=10

# Server
PORT=3000
NODE_ENV=production

# CORS
FRONTEND_URL=*

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Password reset / email
RESET_PASSWORD_URL_BASE="http://localhost:5173"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="HTMLSignage <no-reply@example.com>"

# Cookie security (set to 'true' when using HTTPS)
COOKIE_SECURE=false

# Logging
LOG_HTTP_REQUESTS=0
LOG_HTTP_SLOW_THRESHOLD_MS=1500
# Set to 'debug' to enable verbose WebSocket logs in production
LOG_LEVEL=info

# Graceful shutdown
SHUTDOWN_TIMEOUT_MS=10000

# System update / GitHub release source
GITHUB_REPO=owner/repo
GITHUB_TOKEN=
