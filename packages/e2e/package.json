{
  "name": "@htmlsignage/e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "End-to-end tests using Playwright. Targets a running HTMLSignage stack (frontend + backend) via E2E_BASE_URL.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "install-browsers": "playwright install chromium",
    "install-browsers-with-deps": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.2"
  }
}
